---
import BaseLayout from '../layouts/BaseLayout.astro';

const experience = [
  {
    company: 'Nebius',
    role: 'Customer Engineer',
    place: 'Amsterdam, Netherlands',
    dates: 'Jan 2026 — Present',
    detail:
      'Helping customers succeed on AI cloud infrastructure — from architecture conversations to production readiness across GPU and data platforms.',
  },
  {
    company: 'Nebius',
    role: 'Senior L2 Support Engineer & AI Engineer — Professional Services',
    place: 'Amsterdam, Netherlands',
    dates: 'Jul 2025 — Jan 2026',
    detail:
      'Deep technical ownership across AI infrastructure and professional services engagements.',
  },
  {
    company: 'MongoDB',
    role: 'Technical Services Engineer, Core',
    place: 'Dublin, Ireland',
    dates: 'Mar 2024 — Apr 2025',
    detail:
      'Supported mission-critical MongoDB deployments with architecture guidance and hands-on troubleshooting.',
  },
  {
    company: 'Amazon Web Services',
    role: 'Cloud Support Engineer II — Data Analytics & Generative AI',
    place: 'Dublin, Ireland',
    dates: 'Dec 2023 — Mar 2024',
    detail:
      'Specialized in data analytics and generative AI workloads on AWS.',
  },
  {
    company: 'Amazon Web Services',
    role: 'Technical Account Manager / Cloud Support Engineer',
    place: 'Dublin, Ireland',
    dates: 'Sep 2021 — Nov 2023',
    detail:
      'Guided customers through cloud operations, analytics platforms, and reliability practices. Recognized as SME for Amazon OpenSearch Service.',
  },
  {
    company: 'Olcya',
    client: 'Société Générale',
    role: 'DevOps & Big Data Consulting Engineer',
    place: 'Paris, France',
    dates: 'Sep 2020 — Sep 2021',
    detail:
      'External consultant with Olcya, embedded in Société Générale engineering teams. Built CI/CD pipelines, automated workflows, and administered petabyte-scale Hadoop, Spark, Kafka, and Elasticsearch clusters.',
  },
  {
    company: 'Thales',
    role: 'Big Data Engineer',
    place: 'France',
    dates: 'Sep 2019 — Sep 2020',
    detail:
      'Designed data-driven architectures, REST APIs, and end-to-end pipeline PoCs with customer-facing demos.',
  },
];

const focus = [
  {
    title: 'AI cloud infrastructure',
    text: 'GPU platforms, inference, and production readiness for AI-native teams.',
  },
  {
    title: 'Data platforms',
    text: 'Analytics stacks, search, streaming, and migrations at scale.',
  },
  {
    title: 'Customer engineering',
    text: 'Clear technical storytelling, escalation ownership, and solution design.',
  },
];

const certs = [
  'NVIDIA Certified Associate — AI Infrastructure',
  'AWS Certified Solutions Architect — Associate',
  'AWS Certified Database — Specialty',
  'Microsoft Azure Fundamentals',
  'Alibaba Cloud Associate — Big Data',
  'Alibaba Cloud Associate — Cloud Security',
  'Professional Scrum Master I',
  'ITILv4 Foundation',
];

const companies = [
  {
    name: 'Nebius',
    href: 'https://nebius.com',
    src: '/logos/nebius-mark.svg',
    kind: 'mark',
  },
  {
    name: 'MongoDB',
    href: 'https://www.mongodb.com',
    src: '/logos/mongodb.svg',
    kind: 'wordmark',
  },
  {
    name: 'AWS',
    href: 'https://aws.amazon.com',
    src: '/logos/aws.svg',
    kind: 'wordmark',
  },
  {
    name: 'Société Générale',
    href: 'https://www.societegenerale.com',
    src: '/logos/societe-generale.jpg',
    kind: 'mark',
  },
  {
    name: 'Thales',
    href: 'https://www.thalesgroup.com',
    src: '/logos/thales.svg',
    kind: 'wordmark',
  },
];
---

<BaseLayout>
  <header class="nav">
    <div class="wrap nav__inner">
      <a class="nav__brand" href="#top">Antoine Goze</a>
      <nav class="nav__links" aria-label="Primary">
        <a href="#work">Work</a>
        <a href="#focus">Focus</a>
        <a href="#contact">Contact</a>
      </nav>
    </div>
  </header>

  <main id="top">
    <section class="hero">
      <div class="hero__media" aria-hidden="true">
        <img
          src="https://images.unsplash.com/photo-1558494949-ef010cbdcc31?auto=format&fit=crop&w=2000&q=80"
          alt=""
          width="2000"
          height="1333"
        />
        <div class="hero__veil"></div>
        <div class="hero__scan"></div>
      </div>

      <div class="wrap hero__content">
        <img
          class="hero__photo rise"
          src="/antoine-goze.png"
          alt="Portrait of Antoine Goze"
          width="600"
          height="600"
        />
        <p class="eyebrow rise rise-delay-1">Cloud · AI · Data</p>
        <h1 class="hero__name rise rise-delay-1">Antoine Goze</h1>
        <p class="hero__tag rise rise-delay-2">
          Customer Engineer helping teams ship reliable AI and data platforms —
          from first architecture talk to production.
        </p>
        <div class="hero__actions rise rise-delay-3">
          <a class="btn btn--primary" href="#contact">Get in touch</a>
          <a class="btn btn--ghost" href="https://www.linkedin.com/in/antoinegoze" target="_blank" rel="noopener noreferrer">LinkedIn</a>
          <a class="btn btn--ghost" href="https://github.com/antoinegoze" target="_blank" rel="noopener noreferrer">GitHub</a>
        </div>
      </div>
    </section>

    <section class="logos" aria-label="Companies">
      <div class="wrap">
        <p class="eyebrow logos__label">Previously at</p>
        <ul class="logos__list">
          {
            companies.map((company) => (
              <li>
                <a
                  class:list={['logos__item', `logos__item--${company.kind}`]}
                  href={company.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  title={company.name}
                >
                  <img src={company.src} alt={company.name} />
                  {company.kind === 'mark' && (
                    <span class="logos__name">{company.name}</span>
                  )}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <section class="section about" id="about">
      <div class="wrap about__grid">
        <div>
          <h2 class="section-title">Built for the messy middle of infrastructure.</h2>
        </div>
        <div class="about__copy">
          <p>
            I’m a Customer Engineer based in Amsterdam, with roots in France and
            years across Dublin and Paris. My work sits where cloud platforms,
            AI infrastructure, and customer outcomes meet.
          </p>
          <p>
            Over seven years I’ve supported and advised teams at Nebius, MongoDB,
            AWS, and Thales — plus consulting with Olcya on mission at Société
            Générale — spanning GPU cloud, databases, analytics, DevOps, and
            large-scale data systems.
          </p>
          <p>
            MSc Computer Science, ESEO — Cloud Computing, Security, and Big Data.
          </p>
        </div>
      </div>
    </section>

    <section class="section focus" id="focus">
      <div class="wrap">
        <p class="eyebrow">What I do</p>
        <h2 class="section-title">Focus areas</h2>
        <p class="section-lead">
          Technical depth with customer fluency — translating complex systems into
          clear next steps.
        </p>
        <div class="focus__list">
          {
            focus.map((item) => (
              <article class="focus__item">
                <h3>{item.title}</h3>
                <p>{item.text}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section work" id="work">
      <div class="wrap">
        <p class="eyebrow">Path</p>
        <h2 class="section-title">Experience</h2>
        <p class="section-lead">
          A path from big data engineering into cloud platforms, databases, and AI infrastructure.
        </p>
        <ol class="timeline">
          {
            experience.map((job) => (
              <li class="timeline__item">
                <div class="timeline__meta">
                  <span class="timeline__dates">{job.dates}</span>
                  <span class="timeline__place">{job.place}</span>
                </div>
                <div class="timeline__body">
                  <h3>{job.role}</h3>
                  <p class="timeline__company">
                    {job.company}
                    {job.client && (
                      <span class="timeline__client"> · Client: {job.client}</span>
                    )}
                  </p>
                  <p>{job.detail}</p>
                </div>
              </li>
            ))
          }
        </ol>
      </div>
    </section>

    <section class="section certs" id="certs">
      <div class="wrap">
        <p class="eyebrow">Credentials</p>
        <h2 class="section-title">Selected certifications</h2>
        <ul class="certs__list">
          {certs.map((cert) => <li>{cert}</li>)}
        </ul>
      </div>
    </section>

    <section class="section contact" id="contact">
      <div class="wrap contact__panel">
        <p class="eyebrow">Contact</p>
        <h2 class="section-title">Let’s talk infrastructure.</h2>
        <p class="section-lead">
          Open to conversations about AI cloud, customer engineering, and
          ambitious platform work.
        </p>
        <div class="contact__links">
          <a href="https://www.linkedin.com/in/antoinegoze" target="_blank" rel="noopener noreferrer">
            linkedin.com/in/antoinegoze
          </a>
          <a href="https://github.com/antoinegoze" target="_blank" rel="noopener noreferrer">
            github.com/antoinegoze
          </a>
        </div>
      </div>
    </section>
  </main>

  <footer class="footer">
    <div class="wrap footer__inner">
      <span>© {new Date().getFullYear()} Antoine Goze</span>
      <span>Built with Astro · free & open source</span>
    </div>
  </footer>
</BaseLayout>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 20;
    backdrop-filter: blur(14px);
    background: rgba(8, 16, 13, 0.72);
    border-bottom: 1px solid var(--line);
  }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 4rem;
  }

  .nav__brand {
    font-family: var(--font-display);
    font-weight: 700;
    letter-spacing: -0.03em;
    text-decoration: none;
  }

  .nav__links {
    display: flex;
    gap: 1.25rem;
    font-size: 0.92rem;
  }

  .nav__links a {
    text-decoration: none;
    color: var(--fog);
  }

  .nav__links a:hover {
    color: var(--signal);
  }

  .hero {
    position: relative;
    min-height: 100svh;
    display: grid;
    align-items: center;
    overflow: clip;
    border-bottom: 1px solid var(--line);
  }

  .hero__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(0.75) contrast(1.05) brightness(0.55);
    animation: drift 18s var(--ease) alternate infinite;
  }

  .hero__veil {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(8, 16, 13, 0.45) 0%, rgba(8, 16, 13, 0.72) 45%, rgba(8, 16, 13, 0.94) 100%),
      radial-gradient(circle at 50% 30%, rgba(200, 245, 66, 0.1), transparent 45%);
  }

  .hero__scan {
    position: absolute;
    left: 0;
    right: 0;
    top: 18%;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--signal), transparent);
    animation: pulse-line 3.6s ease-in-out infinite;
  }

  .hero__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding-block: clamp(6rem, 12vh, 8rem) clamp(3rem, 8vh, 5rem);
  }

  .hero__photo {
    width: clamp(7.5rem, 16vw, 9.5rem);
    height: clamp(7.5rem, 16vw, 9.5rem);
    border-radius: 50%;
    object-fit: cover;
    margin-bottom: 1.35rem;
    border: 2px solid rgba(200, 245, 66, 0.45);
    box-shadow: 0 0 0 8px rgba(8, 16, 13, 0.35);
  }

  .hero__name {
    margin-top: 0.55rem;
    font-size: clamp(2.2rem, 5vw, 3.4rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.2;
    color: var(--paper);
    white-space: nowrap;
    padding-block: 0.08em 0.12em;
  }

  .hero__tag {
    margin-top: 1rem;
    max-width: 34rem;
    font-size: clamp(1.02rem, 1.8vw, 1.18rem);
    color: var(--mist);
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
    margin-top: 1.75rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.85rem;
    padding: 0 1.15rem;
    border: 1px solid transparent;
    font-weight: 600;
    text-decoration: none;
    transition: transform 0.2s var(--ease), background 0.2s var(--ease), border-color 0.2s var(--ease);
  }

  .btn:hover {
    transform: translateY(-1px);
  }

  .btn--primary {
    background: var(--signal);
    color: var(--ink);
  }

  .btn--primary:hover {
    background: var(--signal-deep);
    color: var(--ink);
  }

  .btn--ghost {
    border-color: var(--line);
    background: rgba(14, 24, 20, 0.55);
    color: var(--mist);
  }

  .logos {
    padding-block: 2rem 1.25rem;
    border-bottom: 1px solid var(--line);
  }

  .logos__label {
    text-align: center;
    margin-bottom: 1.25rem;
  }

  .logos__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 1.75rem 2.5rem;
  }

  .logos__item {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    text-decoration: none;
    color: var(--mist);
    opacity: 0.78;
    transition: opacity 0.2s var(--ease), transform 0.2s var(--ease);
  }

  .logos__item:hover {
    opacity: 1;
    transform: translateY(-1px);
    color: var(--paper);
  }

  .logos__item img {
    display: block;
    width: auto;
    height: 1.7rem;
    object-fit: contain;
  }

  .logos__item--wordmark img {
    height: 1.85rem;
    filter: brightness(0) invert(0.92);
  }

  .logos__item--mark img {
    height: 1.85rem;
    width: 1.85rem;
    border-radius: 0.35rem;
  }

  .logos__name {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 700;
    letter-spacing: -0.03em;
  }

  .about__grid {
    display: grid;
    gap: var(--space-md);
  }

  @media (min-width: 860px) {
    .about__grid {
      grid-template-columns: 1.1fr 1fr;
      gap: var(--space-xl);
      align-items: start;
    }
  }

  .about__copy {
    display: grid;
    gap: 1rem;
    color: var(--fog);
  }

  .focus__list {
    display: grid;
    gap: 0;
    border-top: 1px solid var(--line);
  }

  .focus__item {
    display: grid;
    gap: 0.5rem;
    padding-block: 1.5rem;
    border-bottom: 1px solid var(--line);
  }

  @media (min-width: 760px) {
    .focus__item {
      grid-template-columns: 0.8fr 1.2fr;
      gap: 2rem;
      align-items: baseline;
    }
  }

  .focus__item h3 {
    font-size: 1.35rem;
    color: var(--paper);
  }

  .focus__item p {
    color: var(--fog);
  }

  .timeline {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--line);
  }

  .timeline__item {
    display: grid;
    gap: 0.75rem;
    padding-block: 1.75rem;
    border-bottom: 1px solid var(--line);
  }

  @media (min-width: 860px) {
    .timeline__item {
      grid-template-columns: 15rem 1fr;
      gap: 2.5rem;
    }
  }

  .timeline__meta {
    display: grid;
    gap: 0.25rem;
    color: var(--fog);
    font-size: 0.92rem;
  }

  .timeline__dates {
    color: var(--signal);
    font-weight: 600;
  }

  .timeline__body h3 {
    font-size: clamp(1.15rem, 2vw, 1.4rem);
    color: var(--paper);
    margin-bottom: 0.35rem;
  }

  .timeline__company {
    color: var(--mist);
    font-weight: 600;
    margin-bottom: 0.55rem;
  }

  .timeline__client {
    color: var(--fog);
    font-weight: 500;
  }

  .timeline__body p:last-child {
    color: var(--fog);
    max-width: 42rem;
  }

  .certs__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0;
    border-top: 1px solid var(--line);
  }

  .certs__list li {
    padding-block: 1rem;
    border-bottom: 1px solid var(--line);
    color: var(--mist);
  }

  .contact__panel {
    padding-block: var(--space-lg);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }

  .contact__links {
    display: grid;
    gap: 0.75rem;
  }

  .contact__links a {
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 3vw, 1.8rem);
    letter-spacing: -0.03em;
    text-decoration: none;
    color: var(--paper);
  }

  .contact__links a:hover {
    color: var(--signal);
  }

  .footer {
    padding-block: 1.5rem 2.5rem;
  }

  .footer__inner {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.75rem;
    color: var(--fog);
    font-size: 0.88rem;
  }
</style>
